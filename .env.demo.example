# Copy to .env.demo for local demo runs or let CI generate the file dynamically.

MYSQL_ROOT_PASSWORD=replace-with-demo-root-password
MYSQL_DATABASE=curaflow_demo_master
MYSQL_USER=curaflow
MYSQL_PASSWORD=replace-with-demo-db-password
CURAFLOW_TENANT_DATABASE=curaflow_demo_tenant

JWT_SECRET=replace-with-demo-jwt-secret
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_URL=http://localhost:3000
PUBLIC_APP_URL=http://localhost:3000

CURAFLOW_DEMO_TENANT_ID=demo-tenant-main
CURAFLOW_DEMO_TENANT_NAME=CuraFlow Demo Tenant
CURAFLOW_DEMO_ADMIN_PASSWORD=replace-with-demo-admin-password-min-12
CURAFLOW_DEMO_USER_PASSWORD=replace-with-demo-user-password-min-12
CURAFLOW_DEMO_READONLY_PASSWORD=replace-with-demo-readonly-password-min-12
CURAFLOW_DEMO_RESET_PASSWORD=replace-with-demo-reset-password-min-12
